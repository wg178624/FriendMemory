# Friend Memory Project environment example
# Copy this file to .env and replace placeholders locally.
# Never commit .env with real credentials.

# Default: heuristic
# Options: heuristic, http, openai-compatible
MEMORY_AI_PROVIDER=heuristic

# OpenAI-compatible chat completions example:
# MEMORY_AI_PROVIDER=openai-compatible
# MEMORY_AI_ENDPOINT=https://api.openai.com/v1/chat/completions
# MEMORY_AI_MODEL=gpt-4.1-mini
# MEMORY_AI_API_KEY=YOUR_KEY

# Custom HTTP MemoryAI worker example:
# MEMORY_AI_PROVIDER=http
# MEMORY_AI_ENDPOINT=http://127.0.0.1:9000/memory-ai
# MEMORY_AI_API_KEY=OPTIONAL_TOKEN

# Request timeout for external AI providers.
MEMORY_AI_TIMEOUT_SECONDS=10

# Set true if external AI failure should stop the operation instead of using local fallback.
MEMORY_AI_DISABLE_FALLBACK=false

# Optional state path override. Prefer a local path outside the repository for real data.
# FRIEND_MEMORY_STATE=/tmp/friend-memory-state.json
